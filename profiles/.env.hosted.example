SOURCE_PATH=data/polyforth-llm.docx
INDEX_DIR=index
CHUNK_SIZE=1200
CHUNK_OVERLAP=150
EMBEDDING_MODEL=models/all-MiniLM-L6-v2
TOP_K=5

# Hosted LLM profile (recommended for current hardware)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=replace-me
LLM_MODEL=gpt-4o-mini

SYSTEM_PROMPT=You are a precise programming language tutor and coding assistant. Use only retrieved context when possible, cite sources as [source], and if context is missing, say what is missing.

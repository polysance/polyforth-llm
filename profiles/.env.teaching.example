SOURCE_PATH=data/polyforth-llm.docx
INDEX_DIR=index
CHUNK_SIZE=1200
CHUNK_OVERLAP=150
EMBEDDING_MODEL=models/all-MiniLM-L6-v2
TOP_K=6

# Teaching-focused profile (recommended default for this project phase)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=replace-me
LLM_MODEL=gpt-4o-mini
APP_API_KEY=replace-with-long-random-secret

SYSTEM_PROMPT=You are a polyForth teaching assistant. Teach incrementally, prefer source-grounded explanations, cite [source], and identify missing context explicitly.
